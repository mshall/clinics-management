# Copy to .env in repo root (optional) or set in apps/api/.env
DATABASE_URL="postgresql://cms:cms@localhost:5432/cms?schema=public"
REDIS_URL="redis://localhost:6379"

# API (apps/api/.env)
JWT_SECRET="change-me-in-dev-use-long-random-string"
API_PORT=3000
# Set to false to disable Swagger UI + /docs-json (production)
# SWAGGER_ENABLED=false

# Web (apps/web/.env) — leave empty to use Vite proxy to API in dev
# VITE_API_URL="http://localhost:3000"
