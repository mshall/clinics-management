# Database — pick one:
#
# Docker Compose (repo root: docker compose up -d) uses user/db/password "cms":
# DATABASE_URL="postgresql://cms:cms@localhost:5432/cms?schema=public"
#
# Local Postgres superuser (default "postgres" DB exists out of the box):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?schema=public"
#
# Or create a dedicated DB first: CREATE DATABASE cms; then:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cms?schema=public"

DATABASE_URL="postgresql://cms:cms@localhost:5432/cms?schema=public"
JWT_SECRET="dev-only-change-in-production-min-32-chars-please"
PORT=3000
SWAGGER_ENABLED=true

# Optional: comma-separated emails that may use GET /admin/tenants and /admin/data-explorer/*.
# Organization GROUP_ADMIN users are not platform operators unless listed here.
# PLATFORM_SUPER_ADMIN_EMAILS=
