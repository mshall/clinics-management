{
  "name": "ahmed-clinic-platform",
  "private": true,
  "workspaces": ["apps/web", "apps/api"],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm run db:setup -w api",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w api\" \"npm run dev -w web\"",
    "dev:e2e": "bash scripts/dev-e2e.sh",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "codegen": "npm run codegen -w web",
    "build": "npm run build -w api && npm run build -w web",
    "lint": "npm run lint -w web",
    "preview": "npm run preview -w web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
